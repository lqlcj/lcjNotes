{"file":"admin-BAziWmVz.js","mappings":"6yBAoPA,MAAMA,EAAkBC,EAAI,EAAK,EAC3BC,EAAgBD,EAAI,EAAE,EACtBE,EAAYF,EAAI,EAAK,EACrBG,EAAaH,EAAI,EAAE,EAEnBI,EAAYJ,EAAI,OAAO,EAEvBK,EAAQL,EAAI,EAAE,EACdM,EAAUN,EAAI,EAAK,EACnBO,EAAiBP,EAAI,EAAK,EAC1BQ,EAAcR,EAAI,IAAI,EACtBS,EAAaT,EAAI,EAAK,EAEtBU,EAAWV,EAAI,EAAE,EACjBW,EAAkBX,EAAI,EAAK,EAC3BY,EAAkBZ,EAAI,EAAK,EAC3Ba,EAAoBb,EAAI,EAAK,EAE7Bc,EAAcd,EAAI,CACtB,KAAM,GACN,MAAO,GACP,QAAS,GACT,QAAS,GACT,KAAM,IAAI,OAAO,YAAW,EAAG,MAAM,EAAG,EAAE,CAC5C,CAAC,EAEKe,EAAWf,EAAI,CACnB,MAAO,GACP,KAAM,IAAI,OAAO,YAAW,EAAG,MAAM,GAAG,EAAE,CAAC,EAC3C,MAAO,GACP,MAAO,IACP,KAAM,MACN,OAAQ,GACR,MAAO,EACP,KAAM,EACR,CAAC,EAiNKgB,EAAcC,GACbA,EACQ,IAAI,KAAKA,CAAU,EACpB,eAAe,QAAS,CAClC,KAAM,UACN,MAAO,UACP,IAAK,UACL,KAAM,UACN,OAAQ,SACZ,CAAG,EARuB,qBAxenBC,EAAA,OAAAC,EAAAC,EAAA,CAAA,MAAM,cAAYC,CAAA,CAAA,CAAA,gEAAA,EAGPtB,EAAA,2QA8BwBK,EAAA,QAAS,QAAA,CAAA,yEAMTA,EAAA,QAAS,WAAA,CAAA,4CAOhCA,EAAA,QAAS,8MASLE,EAAA,6DACKD,EAAA,MAAM,SAAM,6HAKTiB,EAAAjB,EAAA,MAARkB,GAAI,qHAKFC,EAAAD,EAAK,KAAK,0OAOJC,EAAAD,EAAK,IAAI,qCACTC,EAAAD,EAAK,MAAI,KAAA,+EAQrBnB,EAAA,QAAS,oNAQLO,EAAA,6DACKD,EAAA,MAAS,SAAM,kHAKTY,EAAAZ,EAAA,MAAXe,GAAO,+LAOLD,EAAAC,EAAQ,KAAK,UAAU,YAAW,CAAA,wEAG9BD,EAAAC,EAAQ,IAAI,sDACWT,EAAWS,EAAQ,IAAI,CAAA,gIAMtDD,EAAAC,EAAQ,OAAO,WAETA,EAAQ,8DACb,OAAMA,EAAQ,OAAO,qCAAqBD,EAAAC,EAAQ,OAAO,+FAQ5DlB,EAAA,OAAkBC,EAAA,uKAGhBA,EAAA,MAAW,OAAA,MAAA,0KAOAkB,EAAA,QAAAX,EAAA,MAAS,KAAK,qKAMZW,EAAA,QAAAX,EAAA,MAAS,IAAI,4HAIbW,EAAA,QAAAX,EAAA,MAAS,KAAK,iMAOPW,EAAA,QAAAX,EAAA,MAAS,KAAK,sJAIrBW,EAAA,QAAAX,EAAA,MAAS,IAAI,0NAOpBS,EAAAT,EAAA,MAAS,IAAI,iLAS6BN,EAAA,KAAU,EAAA,YAAA,wBAC1DA,EAAA,MAAU,SAAA,IAAA,oDAQZG,EAAA,qXAWec,EAAA,QAAAZ,EAAA,MAAY,IAAI,+HAIhBY,EAAA,QAAAZ,EAAA,MAAY,KAAK,6HAMnBY,EAAA,QAAAZ,EAAA,MAAY,OAAO,uNAMxBU,EAAAV,EAAA,MAAY,OAAO,kHAUnBY,EAAA,QAAAZ,EAAA,MAAY,IAAI,6MAO0BD,EAAA,KAAiB,EAAA,YAAA,wBACjEA,EAAA,MAAiB,SAAA,IAAA,wQAxNfZ,EAAA,KAAa,sHAM2BC,EAAA,KAAS,EAAA,YAAA,wBACzDA,EAAA,MAAS,SAAA,IAAA,cAELC,EAAA,8CAA6BA,EAAA,KAAU,CAAA,MAAA","names":["isAuthenticated","ref","loginPassword","loggingIn","loginError","activeTab","posts","loading","showCreateForm","editingPost","submitting","messages","messagesLoading","showMessageForm","submittingMessage","messageForm","formData","formatDate","dateString","_push","_ssrRenderAttrs","_mergeProps","_attrs","_ssrRenderList","post","_ssrInterpolate","message","_ssrRenderAttr"],"sources":["../../../../../pages/admin.vue"],"sourcesContent":["<template>\n  <div class=\"admin-page\">\n    <div class=\"admin-container\">\n      <!-- 登录界面 -->\n      <div v-if=\"!isAuthenticated\" class=\"login-form glass-card\">\n        <h2>后台管理登录</h2>\n        <form @submit.prevent=\"handleLogin\">\n          <div class=\"form-group\">\n            <label>密码</label>\n            <input \n              v-model=\"loginPassword\" \n              type=\"password\" \n              placeholder=\"请输入管理员密码\"\n              required\n            />\n          </div>\n          <button type=\"submit\" class=\"btn-primary\" :disabled=\"loggingIn\">\n            {{ loggingIn ? '登录中...' : '登录' }}\n          </button>\n          <p v-if=\"loginError\" class=\"error\">{{ loginError }}</p>\n        </form>\n      </div>\n\n      <!-- 管理界面 -->\n      <div v-else class=\"admin-panel\">\n        <div class=\"admin-header\">\n          <h1>博客管理后台</h1>\n          <button @click=\"handleLogout\" class=\"btn-secondary\">退出登录</button>\n        </div>\n\n        <!-- 标签页切换 -->\n        <div class=\"admin-tabs\">\n          <button \n            @click=\"activeTab = 'posts'\" \n            :class=\"['tab-btn', { active: activeTab === 'posts' }]\"\n          >\n            文章管理\n          </button>\n          <button \n            @click=\"activeTab = 'messages'\" \n            :class=\"['tab-btn', { active: activeTab === 'messages' }]\"\n          >\n            留言管理\n          </button>\n        </div>\n\n        <!-- 文章管理 -->\n        <div v-if=\"activeTab === 'posts'\" class=\"tab-content\">\n          <div class=\"admin-actions\">\n            <button @click=\"showCreateForm = true\" class=\"btn-primary\">\n              + 新建文章\n            </button>\n          </div>\n\n          <!-- 文章列表 -->\n          <div class=\"posts-list\">\n            <div v-if=\"loading\" class=\"loading\">加载中...</div>\n            <div v-else-if=\"posts.length === 0\" class=\"empty\">\n              还没有文章，点击上方按钮创建第一篇吧！\n            </div>\n            <div v-else class=\"posts-grid\">\n              <div \n                v-for=\"post in posts\" \n                :key=\"post.id\" \n                class=\"post-card glass-card\"\n              >\n                <div class=\"post-header\">\n                  <h3>{{ post.title }}</h3>\n                  <div class=\"post-actions\">\n                    <button @click=\"editPost(post)\" class=\"btn-edit\">编辑</button>\n                    <button @click=\"deletePost(post.id)\" class=\"btn-delete\">删除</button>\n                  </div>\n                </div>\n                <div class=\"post-meta\">\n                  <span>日期: {{ post.date }}</span>\n                  <span>作者: {{ post.user || 'lcj' }}</span>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        <!-- 留言管理 -->\n        <div v-if=\"activeTab === 'messages'\" class=\"tab-content\">\n          <div class=\"admin-actions\">\n            <button @click=\"showMessageForm = true\" class=\"btn-primary\">\n              + 添加留言\n            </button>\n          </div>\n          \n          <div class=\"messages-list\">\n            <div v-if=\"messagesLoading\" class=\"loading\">加载中...</div>\n            <div v-else-if=\"messages.length === 0\" class=\"empty\">\n              还没有留言\n            </div>\n            <div v-else class=\"messages-grid\">\n              <div \n                v-for=\"message in messages\" \n                :key=\"message.id\" \n                class=\"message-card glass-card\"\n              >\n                <div class=\"message-header\">\n                  <div class=\"message-author\">\n                    <div class=\"message-avatar\">\n                      {{ message.name.charAt(0).toUpperCase() }}\n                    </div>\n                    <div class=\"message-info\">\n                      <h4>{{ message.name }}</h4>\n                      <span class=\"message-date\">{{ formatDate(message.date) }}</span>\n                    </div>\n                  </div>\n                  <button @click=\"deleteMessage(message.id)\" class=\"btn-delete\">删除</button>\n                </div>\n                <div class=\"message-content\">\n                  {{ message.content }}\n                </div>\n                <div v-if=\"message.website\" class=\"message-website\">\n                  <a :href=\"message.website\" target=\"_blank\">{{ message.website }}</a>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        <!-- 创建/编辑文章表单 -->\n        <div v-if=\"showCreateForm || editingPost\" class=\"form-modal\">\n          <div class=\"form-content glass-card\">\n            <div class=\"form-header\">\n              <h2>{{ editingPost ? '编辑文章' : '新建文章' }}</h2>\n              <button @click=\"closeForm\" class=\"close-btn\">×</button>\n            </div>\n            \n            <form @submit.prevent=\"handleSubmit\">\n              <div class=\"form-group\">\n                <label>标题 *</label>\n                <input v-model=\"formData.title\" type=\"text\" required />\n              </div>\n\n              <div class=\"form-row\">\n                <div class=\"form-group\">\n                  <label>日期</label>\n                  <input v-model=\"formData.date\" type=\"date\" />\n                </div>\n                <div class=\"form-group\">\n                  <label>封面图片 URL</label>\n                  <input v-model=\"formData.cover\" type=\"text\" placeholder=\"/images/01.webp\" />\n                </div>\n              </div>\n\n              <div class=\"form-row\">\n                <div class=\"form-group\">\n                  <label>宽高比</label>\n                  <input v-model.number=\"formData.ratio\" type=\"number\" step=\"0.01\" min=\"0.5\" max=\"2\" />\n                </div>\n                <div class=\"form-group\">\n                  <label>作者</label>\n                  <input v-model=\"formData.user\" type=\"text\" />\n                </div>\n              </div>\n\n              <div class=\"form-group\">\n                <label>文章内容 (Markdown) *</label>\n                <textarea \n                  v-model=\"formData.body\" \n                  rows=\"20\" \n                  required\n                  placeholder=\"在这里输入 Markdown 格式的文章内容...\"\n                ></textarea>\n              </div>\n\n              <div class=\"form-actions\">\n                <button type=\"button\" @click=\"closeForm\" class=\"btn-secondary\">取消</button>\n                <button type=\"submit\" class=\"btn-primary\" :disabled=\"submitting\">\n                  {{ submitting ? '保存中...' : '保存' }}\n                </button>\n              </div>\n            </form>\n          </div>\n        </div>\n\n        <!-- 创建留言表单 -->\n        <div v-if=\"showMessageForm\" class=\"form-modal\">\n          <div class=\"form-content glass-card\">\n            <div class=\"form-header\">\n              <h2>添加留言</h2>\n              <button @click=\"closeMessageForm\" class=\"close-btn\">×</button>\n            </div>\n            \n            <form @submit.prevent=\"handleMessageSubmit\">\n              <div class=\"form-row\">\n                <div class=\"form-group\">\n                  <label>姓名 *</label>\n                  <input v-model=\"messageForm.name\" type=\"text\" required />\n                </div>\n                <div class=\"form-group\">\n                  <label>邮箱</label>\n                  <input v-model=\"messageForm.email\" type=\"email\" />\n                </div>\n              </div>\n\n              <div class=\"form-group\">\n                <label>网站</label>\n                <input v-model=\"messageForm.website\" type=\"url\" placeholder=\"https://example.com\" />\n              </div>\n\n              <div class=\"form-group\">\n                <label>留言内容 *</label>\n                <textarea \n                  v-model=\"messageForm.content\" \n                  rows=\"6\" \n                  required\n                  placeholder=\"留言内容...\"\n                ></textarea>\n              </div>\n\n              <div class=\"form-group\">\n                <label>时间（可选，留空则使用当前时间）</label>\n                <input \n                  v-model=\"messageForm.date\" \n                  type=\"datetime-local\"\n                />\n              </div>\n\n              <div class=\"form-actions\">\n                <button type=\"button\" @click=\"closeMessageForm\" class=\"btn-secondary\">取消</button>\n                <button type=\"submit\" class=\"btn-primary\" :disabled=\"submittingMessage\">\n                  {{ submittingMessage ? '提交中...' : '提交' }}\n                </button>\n              </div>\n            </form>\n          </div>\n        </div>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script setup>\nimport { ref, onMounted } from 'vue';\n\ndefinePageMeta({\n  layout: false\n});\n\nconst isAuthenticated = ref(false);\nconst loginPassword = ref('');\nconst loggingIn = ref(false);\nconst loginError = ref('');\n\nconst activeTab = ref('posts'); // 'posts' 或 'messages'\n\nconst posts = ref([]);\nconst loading = ref(false);\nconst showCreateForm = ref(false);\nconst editingPost = ref(null);\nconst submitting = ref(false);\n\nconst messages = ref([]);\nconst messagesLoading = ref(false);\nconst showMessageForm = ref(false);\nconst submittingMessage = ref(false);\n\nconst messageForm = ref({\n  name: '',\n  email: '',\n  website: '',\n  content: '',\n  date: new Date().toISOString().slice(0, 16) // 默认使用当前时间\n});\n\nconst formData = ref({\n  title: '',\n  date: new Date().toISOString().split('T')[0],\n  cover: '',\n  ratio: 0.75,\n  user: 'lcj',\n  avatar: '',\n  likes: 0,\n  body: ''\n});\n\n// 检查是否已登录\nonMounted(() => {\n  const token = localStorage.getItem('admin_token');\n  if (token) {\n    isAuthenticated.value = true;\n    loadPosts();\n    loadMessages();\n  }\n});\n\n// 登录\nconst handleLogin = async () => {\n  loggingIn.value = true;\n  loginError.value = '';\n  \n  try {\n    const response = await $fetch('/api/auth/login', {\n      method: 'POST',\n      body: {\n        password: loginPassword.value\n      }\n    });\n    \n    if (response.success) {\n      localStorage.setItem('admin_token', response.token);\n      isAuthenticated.value = true;\n      loginPassword.value = '';\n      loadPosts();\n      loadMessages();\n    }\n  } catch (error) {\n    loginError.value = error?.data?.message || '登录失败';\n  } finally {\n    loggingIn.value = false;\n  }\n};\n\n// 退出登录\nconst handleLogout = () => {\n  localStorage.removeItem('admin_token');\n  isAuthenticated.value = false;\n  posts.value = [];\n};\n\n// 加载文章列表\nconst loadPosts = async () => {\n  loading.value = true;\n  try {\n    const response = await $fetch('/api/posts');\n    if (response.success) {\n      posts.value = response.data;\n    }\n  } catch (error) {\n    console.error('加载文章失败:', error);\n  } finally {\n    loading.value = false;\n  }\n};\n\n// 编辑文章\nconst editPost = async (post) => {\n  try {\n    const response = await $fetch(`/api/posts/${post.id}`);\n    if (response.success) {\n      editingPost.value = response.data;\n      formData.value = {\n        title: response.data.title,\n        date: response.data.date,\n        cover: response.data.cover || '',\n        ratio: response.data.ratio || 0.75,\n        user: response.data.user || 'lcj',\n        avatar: response.data.avatar || '',\n        likes: response.data.likes || 0,\n        body: response.data.body\n      };\n      showCreateForm.value = true;\n    }\n  } catch (error) {\n    console.error('加载文章失败:', error);\n    alert('加载文章失败');\n  }\n};\n\n// 删除文章\nconst deletePost = async (id) => {\n  if (!confirm('确定要删除这篇文章吗？')) {\n    return;\n  }\n  \n  const token = localStorage.getItem('admin_token');\n  try {\n    const response = await $fetch(`/api/posts/${id}`, {\n      method: 'DELETE',\n      headers: {\n        'Authorization': `Bearer ${token}`\n      }\n    });\n    \n    if (response.success) {\n      alert('删除成功');\n      loadPosts();\n    }\n  } catch (error) {\n    alert(error?.data?.message || '删除失败');\n  }\n};\n\n// 提交表单\nconst handleSubmit = async () => {\n  submitting.value = true;\n  const token = localStorage.getItem('admin_token');\n  \n  try {\n    if (editingPost.value) {\n      // 更新文章\n      const response = await $fetch(`/api/posts/${editingPost.value.id}`, {\n        method: 'PUT',\n        headers: {\n          'Authorization': `Bearer ${token}`\n        },\n        body: formData.value\n      });\n      \n      if (response.success) {\n        alert('更新成功');\n        closeForm();\n        loadPosts();\n      }\n    } else {\n      // 创建文章\n      const response = await $fetch('/api/posts', {\n        method: 'POST',\n        headers: {\n          'Authorization': `Bearer ${token}`\n        },\n        body: formData.value\n      });\n      \n      if (response.success) {\n        alert('创建成功');\n        closeForm();\n        loadPosts();\n      }\n    }\n  } catch (error) {\n    alert(error?.data?.message || '保存失败');\n  } finally {\n    submitting.value = false;\n  }\n};\n\n// 关闭表单\nconst closeForm = () => {\n  showCreateForm.value = false;\n  editingPost.value = null;\n  formData.value = {\n    title: '',\n    date: new Date().toISOString().split('T')[0],\n    cover: '',\n    ratio: 0.75,\n    user: 'lcj',\n    avatar: '',\n    likes: 0,\n    body: ''\n  };\n};\n\n// 加载留言列表\nconst loadMessages = async () => {\n  messagesLoading.value = true;\n  try {\n    const response = await $fetch('/api/messages');\n    if (response.success) {\n      messages.value = response.data;\n    }\n  } catch (error) {\n    console.error('加载留言失败:', error);\n  } finally {\n    messagesLoading.value = false;\n  }\n};\n\n// 删除留言\nconst deleteMessage = async (id) => {\n  if (!confirm('确定要删除这条留言吗？')) {\n    return;\n  }\n  \n  const token = localStorage.getItem('admin_token');\n  try {\n    const response = await $fetch(`/api/messages/${id}`, {\n      method: 'DELETE',\n      headers: {\n        'Authorization': `Bearer ${token}`\n      }\n    });\n    \n    if (response.success) {\n      alert('删除成功');\n      loadMessages();\n    }\n  } catch (error) {\n    alert(error?.data?.message || '删除失败');\n  }\n};\n\n// 格式化日期\nconst formatDate = (dateString) => {\n  if (!dateString) return '';\n  const date = new Date(dateString);\n  return date.toLocaleString('zh-CN', {\n    year: 'numeric',\n    month: '2-digit',\n    day: '2-digit',\n    hour: '2-digit',\n    minute: '2-digit'\n  });\n};\n\n// 提交留言表单\nconst handleMessageSubmit = async () => {\n  submittingMessage.value = true;\n  const token = localStorage.getItem('admin_token');\n  \n  try {\n    const response = await $fetch('/api/messages', {\n      method: 'POST',\n      headers: {\n        'Authorization': `Bearer ${token}`\n      },\n      body: {\n        name: messageForm.value.name,\n        email: messageForm.value.email,\n        website: messageForm.value.website,\n        content: messageForm.value.content,\n        date: messageForm.value.date || undefined // 如果设置了时间，传递时间\n      }\n    });\n    \n    if (response.success) {\n      alert('留言创建成功');\n      closeMessageForm();\n      loadMessages();\n    }\n  } catch (error) {\n    alert(error?.data?.message || '创建失败');\n  } finally {\n    submittingMessage.value = false;\n  }\n};\n\n// 关闭留言表单\nconst closeMessageForm = () => {\n  showMessageForm.value = false;\n  messageForm.value = {\n    name: '',\n    email: '',\n    website: '',\n    content: '',\n    date: new Date().toISOString().slice(0, 16) // 重置为当前时间\n  };\n};\n</script>\n\n<style scoped>\n.admin-page {\n  min-height: 100vh;\n  background: linear-gradient(135deg, #FFDDE1 0%, #E0C3FC 100%);\n  padding: 40px 20px;\n}\n\n.admin-container {\n  max-width: 1200px;\n  margin: 0 auto;\n}\n\n.glass-card {\n  background: rgba(255, 255, 255, 0.9);\n  backdrop-filter: blur(15px);\n  border: 1px solid rgba(255, 255, 255, 0.8);\n  border-radius: 12px;\n  box-shadow: 0 5px 25px rgba(0, 0, 0, 0.08);\n  padding: 30px;\n}\n\n/* 登录表单 */\n.login-form {\n  max-width: 400px;\n  margin: 100px auto;\n}\n\n.login-form h2 {\n  margin-bottom: 20px;\n  text-align: center;\n  color: #333;\n}\n\n.form-group {\n  margin-bottom: 20px;\n}\n\n.form-group label {\n  display: block;\n  margin-bottom: 8px;\n  color: #555;\n  font-weight: 500;\n}\n\n.form-group input,\n.form-group textarea {\n  width: 100%;\n  padding: 10px;\n  border: 1px solid #ddd;\n  border-radius: 6px;\n  font-size: 14px;\n  box-sizing: border-box;\n}\n\n.form-group textarea {\n  font-family: monospace;\n  resize: vertical;\n}\n\n.form-row {\n  display: grid;\n  grid-template-columns: 1fr 1fr;\n  gap: 15px;\n}\n\n.btn-primary {\n  width: 100%;\n  padding: 12px;\n  background: #6c5ce7;\n  color: white;\n  border: none;\n  border-radius: 6px;\n  font-size: 16px;\n  cursor: pointer;\n  transition: background 0.3s;\n}\n\n.btn-primary:hover:not(:disabled) {\n  background: #5a4fcf;\n}\n\n.btn-primary:disabled {\n  opacity: 0.6;\n  cursor: not-allowed;\n}\n\n.btn-secondary {\n  padding: 8px 16px;\n  background: #95a5a6;\n  color: white;\n  border: none;\n  border-radius: 6px;\n  cursor: pointer;\n  transition: background 0.3s;\n}\n\n.btn-secondary:hover {\n  background: #7f8c8d;\n}\n\n.error {\n  color: #e74c3c;\n  margin-top: 10px;\n  font-size: 14px;\n}\n\n/* 管理面板 */\n.admin-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  margin-bottom: 30px;\n}\n\n.admin-header h1 {\n  color: #333;\n  margin: 0;\n}\n\n/* 标