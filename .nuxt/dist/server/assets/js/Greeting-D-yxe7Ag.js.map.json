{"file":"Greeting-D-yxe7Ag.js","mappings":"2tBAoCE,MAAMA,EAAeC,GAnBD,IAAM,CAExB,MAAMC,EAAO,IAAI,KAAI,EAAG,SAAQ,EAGhC,OAAIA,GAAQ,GAAKA,EAAO,GACf,0BAGAA,GAAQ,IAAMA,EAAO,GACrB,4BAIA,yBAEX,GAGoC,CAAE,6BAnCjCC,EAAAC,EAAA,CAAA,MAAM,oBAAoB,EAAAC,CAAA,CAAA,gHAEDL,EAAA,KAAY","names":["greetingText","ref","hour","_ssrRenderAttrs","_mergeProps","_attrs"],"sources":["../../../../../pages/home/components/Greeting.vue"],"sourcesContent":["<template>\n  <div class=\"greeting-container\">\n    <div class=\"divider-line\"></div>\n    <p class=\"greeting-text\">{{ greetingText }}</p>\n    <div class=\"divider-line\"></div>\n  </div>\n</template>\n\n<script setup>\n  import { ref, onMounted, onBeforeUnmount } from 'vue'\n\n  // --- 核心修改在这里 ---\n\n  // 1. 删除了所有复杂的 getChinaHour 函数\n  //    我们不需要关心中国时区，只需要关心你电脑的本地时间\n\n  // 2. 修改 getGreeting 函数，让它使用最简单的本地时间\n  const getGreeting = () => {\n    // 核心：直接获取用户电脑的本地小时\n    const hour = new Date().getHours()\n\n    // 6:00-11:00 早上\n    if (hour >= 6 && hour < 11) {\n      return 'Good morning, Traveler.'\n    }\n    // 11:00-18:00 下午\n    else if (hour >= 11 && hour < 18) {\n      return 'Good afternoon, Traveler.'\n    }\n    // 18:00-6:00 晚上/夜里\n    else {\n      return 'Good evening, Traveler.'\n    }\n  }\n\n  // 3. 用【本地时间】来初始化 ref\n  const greetingText = ref(getGreeting())\n\n  // --- 后面的逻辑都是你原来的，它们是正确的 ---\n\n  // 更新问候语\n  const updateGreeting = () => {\n    const newGreeting = getGreeting()\n    if (greetingText.value !== newGreeting) {\n      greetingText.value = newGreeting\n    }\n  }\n\n  // 定时器\n  let timeUpdateTimer = null\n\n  onMounted(() => {\n    // 立即更新一次\n    updateGreeting()\n\n    // 每5秒检查一次时间（确保跨小时时能及时更新）\n    timeUpdateTimer = setInterval(() => {\n      updateGreeting()\n    }, 5000) // 5秒检查一次\n  })\n\n  onBeforeUnmount(() => {\n    if (timeUpdateTimer) {\n      clearInterval(timeUpdateTimer)\n      timeUpdateTimer = null\n    }\n  })\n</script>\n\n<style scoped>\n  .greeting-container {\n    width: 100%;\n    display: flex;\n    justify-content: center;\n    align-items: center;\n    padding: 20px 0;\n    gap: 24px;\n    animation: fadeInUp 0.6s ease 0.5s both;\n  }\n\n  .divider-line {\n    flex: 1;\n    height: 1px;\n    background: linear-gradient(to right, transparent, #d4c5b0, transparent);\n    max-width: 200px;\n  }\n\n  .greeting-text {\n    font-size: 3rem;\n    font-weight: 400;\n    color: #2c3e50;\n    margin: 0;\n    letter-spacing: 2px;\n    font-family: 'Caveat', 'Conv_FuturaStd-Book', cursive;\n    line-height: 1.4;\n    text-align: center;\n    white-space: nowrap;\n  }\n\n  @keyframes fadeInUp {\n    from {\n      opacity: 0;\n      transform: translateY(20px);\n    }\n\n    to {\n      opacity: 1;\n      transform: translateY(0);\n    }\n  }\n\n  /* 响应式设计 */\n  @media (max-width: 768px) {\n    .greeting-container {\n      padding: 15px 0;\n      gap: 16px;\n    }\n\n    .greeting-text {\n      font-size: 2.2rem;\n      letter-spacing: 1px;\n    }\n\n    .divider-line {\n      max-width: 100px;\n    }\n  }\n\n  /* 可访问性优化 */\n  @media (prefers-reduced-motion: reduce) {\n    .greeting-container {\n      animation: none;\n    }\n  }\n</style>\n"],"version":3}