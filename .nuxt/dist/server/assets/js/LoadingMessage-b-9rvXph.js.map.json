{"file":"LoadingMessage-b-9rvXph.js","mappings":"sVACOA,EAAAC,EAAA,CAAA,MAAM,mBAAmB,EAAAC,CAAA,CAAA,4SAUCC,EAAA,IAAI","names":["_ssrRenderAttrs","_mergeProps","_attrs","__props"],"sources":["../../../../../components/Common/LoadingMessage.vue"],"sourcesContent":["<template>\r\n  <div class=\"loading-container\">\r\n    <div class=\"loading-content\">\r\n      <!-- 加载动画 -->\r\n      <div class=\"loading-spinner\">\r\n        <div class=\"spinner-dot\"></div>\r\n        <div class=\"spinner-dot\"></div>\r\n        <div class=\"spinner-dot\"></div>\r\n      </div>\r\n      \r\n      <!-- 加载文字 -->\r\n      <p class=\"loading-text\">{{ text }}</p>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script setup>\r\n  defineProps({\r\n    text: {\r\n      type: String,\r\n      default: '飘洋过海来看你~'\r\n    }\r\n  })\r\n</script>\r\n\r\n<style scoped>\r\n  .loading-container {\r\n    display: flex;\r\n    align-items: center;\r\n    justify-content: center;\r\n    min-height: 200px;\r\n    padding: 40px 20px;\r\n    width: 100%;\r\n  }\r\n\r\n  .loading-content {\r\n    display: flex;\r\n    flex-direction: column;\r\n    align-items: center;\r\n    gap: 24px;\r\n  }\r\n\r\n  /* 加载动画 - 三个点的跳动效果 */\r\n  .loading-spinner {\r\n    display: flex;\r\n    gap: 10px;\r\n    align-items: center;\r\n    justify-content: center;\r\n  }\r\n\r\n  .spinner-dot {\r\n    width: 12px;\r\n    height: 12px;\r\n    border-radius: 50%;\r\n    background: linear-gradient(135deg, #ff9a9e 0%, #fecfef 50%, #e0c3fc 100%);\r\n    animation: bounce 1.4s ease-in-out infinite both;\r\n    box-shadow: 0 2px 10px rgba(255, 154, 158, 0.4);\r\n  }\r\n\r\n  .spinner-dot:nth-child(1) {\r\n    animation-delay: -0.32s;\r\n  }\r\n\r\n  .spinner-dot:nth-child(2) {\r\n    animation-delay: -0.16s;\r\n  }\r\n\r\n  .spinner-dot:nth-child(3) {\r\n    animation-delay: 0s;\r\n  }\r\n\r\n  @keyframes bounce {\r\n    0%, 80%, 100% {\r\n      transform: scale(0.8) translateY(0);\r\n      opacity: 0.5;\r\n    }\r\n    40% {\r\n      transform: scale(1.2) translateY(-12px);\r\n      opacity: 1;\r\n    }\r\n  }\r\n\r\n  /* 加载文字样式 */\r\n  .loading-text {\r\n    font-size: 16px;\r\n    color: #666;\r\n    margin: 0;\r\n    font-family: -apple-system, BlinkMacSystemFont, \"Helvetica Neue\", \"PingFang SC\", \"Microsoft YaHei\", sans-serif;\r\n    font-weight: 400;\r\n    letter-spacing: 2px;\r\n    animation: fadeInOut 2s ease-in-out infinite;\r\n    text-align: center;\r\n    position: relative;\r\n  }\r\n\r\n  .loading-text::before {\r\n    content: '🌊';\r\n    display: inline-block;\r\n    margin-right: 8px;\r\n    animation: wave 2s ease-in-out infinite;\r\n  }\r\n\r\n  @keyframes wave {\r\n    0%, 100% {\r\n      transform: translateY(0) rotate(0deg);\r\n    }\r\n    25% {\r\n      transform: translateY(-4px) rotate(-5deg);\r\n    }\r\n    75% {\r\n      transform: translateY(-4px) rotate(5deg);\r\n    }\r\n  }\r\n\r\n  @keyframes fadeInOut {\r\n    0%, 100% {\r\n      opacity: 0.6;\r\n    }\r\n    50% {\r\n      opacity: 1;\r\n    }\r\n  }\r\n\r\n  /* 响应式设计 */\r\n  @media (max-width: 768px) {\r\n    .loading-container {\r\n      min-height: 150px;\r\n      padding: 30px 15px;\r\n    }\r\n\r\n    .loading-content {\r\n      gap: 20px;\r\n    }\r\n\r\n    .loading-text {\r\n      font-size: 14px;\r\n    }\r\n\r\n    .spinner-dot {\r\n      width: 8px;\r\n      height: 8px;\r\n    }\r\n  }\r\n\r\n  /* 支持减少动画偏好 */\r\n  @media (prefers-reduced-motion: reduce) {\r\n    .spinner-dot {\r\n      animation: none;\r\n      opacity: 1;\r\n    }\r\n\r\n    .loading-text {\r\n      animation: none;\r\n      opacity: 1;\r\n    }\r\n  }\r\n</style>\r\n\r\n"],"version":3}